#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage:
  .agents/bin/install-skill --target <category/skill-name> [installer args...]

Examples:
  .agents/bin/install-skill \
    --target planning/foo \
    --repo owner/repo \
    --path skills/foo

  .agents/bin/install-skill \
    --target planning/foo \
    --url https://github.com/owner/repo/tree/main/skills/foo

The target must be a two-segment public path, such as planning/foo.
The skill is installed under .agents/installed-skills/<category>/<skill-name>.
Add a personal wrapper under .agents/skills/<category>/<skill-name> when you want runtime routing.
Run 'nix run .#switch -- <profile>' to deploy authored skills via agent-skills-nix.
EOF
}

target=""
installer_args=()

while [ "$#" -gt 0 ]; do
  case "$1" in
    --target)
      if [ "$#" -lt 2 ]; then
        echo "Error: --target requires a value" >&2
        exit 1
      fi
      target="$2"
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      installer_args+=("$1")
      shift
      ;;
  esac
done

if [ -z "$target" ]; then
  echo "Error: --target is required" >&2
  usage >&2
  exit 1
fi

if [[ "$target" = /* || "$target" = *..* || "$target" = *//* || "$target" != */* || "$target" = */*/* ]]; then
  echo "Error: --target must be a safe two-segment path like category/skill-name" >&2
  exit 1
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
agents_dir="$(cd "$script_dir/.." && pwd)"

category="${target%/*}"
skill_name="${target##*/}"
dest_root="$agents_dir/installed-skills/$category"
dest_dir="$dest_root/$skill_name"

if [ -z "$category" ] || [ -z "$skill_name" ] || [ "$skill_name" = "." ] || [ "$skill_name" = ".." ]; then
  echo "Error: --target must be a safe path like category/skill-name" >&2
  exit 1
fi

if [ -e "$agents_dir/skills/$target" ]; then
  echo "Error: public target already exists in authored skills: .agents/skills/$target" >&2
  exit 1
fi

if [ -e "$dest_dir" ]; then
  echo "Error: installed skill already exists: $dest_dir" >&2
  exit 1
fi

installer="${CODEX_SKILL_INSTALLER:-$HOME/.codex/skills/.system/skill-installer/scripts/install-skill-from-github.py}"

if [ ! -f "$installer" ]; then
  echo "Error: skill installer not found: $installer" >&2
  exit 1
fi

mkdir -p "$dest_root"
python3 "$installer" --dest "$dest_root" --name "$skill_name" "${installer_args[@]}"

cat <<EOF

Installed skill source:
  $dest_dir

Public target:
  $target

Next steps:
  1. Add a personal wrapper under .agents/skills/$target if you want runtime routing
  2. Run 'nix run .#switch -- <profile>' to deploy authored skills via agent-skills-nix
EOF
