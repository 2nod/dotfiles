#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-}"
remote_url="${2:-}"

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
allowlist_file="${HOOK_ALLOWLIST_FILE:-$script_dir/pre-push.allowlist}"

is_allowlisted_remote() {
  local allowed_remote_url

  if [[ ! -f "$allowlist_file" ]]; then
    return 1
  fi

  while IFS= read -r allowed_remote_url; do
    [[ -n "$allowed_remote_url" ]] || continue
    [[ "${allowed_remote_url#\#}" != "$allowed_remote_url" ]] && continue

    if [[ "$remote_url" == "$allowed_remote_url" ]]; then
      return 0
    fi
  done < "$allowlist_file"

  return 1
}

while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      if is_allowlisted_remote; then
        continue
      fi

      echo "pre-push: refusing direct push to protected branch: $remote_ref" >&2
      echo "pre-push: push to a feature branch and open a PR instead." >&2
      echo "pre-push: add the remote URL to $allowlist_file to allow it." >&2
      exit 1
      ;;
  esac
done

exit 0
