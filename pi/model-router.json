{
  "debug": false,
  "classifierModel": "mini",
  "phaseBias": 0.5,
  "maxSessionBudget": 5.0,
  "models": {
    "sol": {
      "model": "openai-codex/gpt-5.6-sol",
      "contextWindow": 372000,
      "maxTokens": 128000
    },
    "gpt55": {
      "model": "openai-codex/gpt-5.5",
      "contextWindow": 272000,
      "maxTokens": 128000
    },
    "mini": {
      "model": "openai-codex/gpt-5.4-mini",
      "contextWindow": 272000,
      "maxTokens": 128000
    },
    "opus": {
      "model": "anthropic/claude-opus-4-8",
      "contextWindow": 1000000,
      "maxTokens": 128000
    },
    "sonnet": {
      "model": "anthropic/claude-sonnet-5",
      "contextWindow": 1000000,
      "maxTokens": 128000
    }
  },
  "rules": [
    {
      "matches": ["deploy", "production", "release", "migration"],
      "tier": "high",
      "reason": "本番・移行系は慎重に上位 tier へ"
    },
    { "matches": ["changelog", "typo", "rename", "format"], "tier": "low" }
  ],
  "profiles": {
    "auto": {
      "high": { "model": "sol", "thinking": "high" },
      "medium": { "model": "gpt55", "thinking": "medium" },
      "low": { "model": "mini", "thinking": "low" }
    },
    "claude": {
      "high": { "model": "opus", "thinking": "high" },
      "medium": { "model": "sonnet", "thinking": "medium" },
      "low": { "model": "sonnet", "thinking": "low" }
    }
  }
}
